{
  "name": "Ubuntu XFCE Desktop",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "codespace",
  "forwardPorts": [5901],
  "customizations": {
    "vscode": {
      "extensions": ["ms-vscode-remote.remote-containers"]
    }
  },
  "postStartCommand": "vncserver :1 -geometry 1280x800 -depth 24"
}
