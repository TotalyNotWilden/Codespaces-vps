{
  "name": "Ubuntu XFCE Desktop",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "codespace",
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "codespace",
      "webPort": "6080",
      "vncPort": "5901"
    }
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Desktop",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers"
      ]
    }
  }
}
